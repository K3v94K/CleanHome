<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="16dp"
    android:layout_marginBottom="16dp"
    android:elevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tv_item_solicitud_cliente"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            tools:text="Nombre del Cliente"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tv_item_solicitud_estado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Pendiente"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FF9800"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_item_solicitud_servicio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="LIMPIEZA GENERAL"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#666666"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_item_solicitud_fecha"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="📅 15 de Noviembre - 10:00 AM"
        android:textColor="#666666"
        android:layout_marginTop="8dp"/>

    <TextView
        android:id="@+id/tv_item_solicitud_direccion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="📍 Colonia Condesa, Calle Ámsterdam 45"
        android:textColor="#666666"
        android:layout_marginTop="4dp"/>

    <Button
        android:id="@+id/btn_item_solicitud_asignar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Asignar Empleado"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0D6EFD"
        android:layout_marginTop="16dp"/>

</LinearLayout>