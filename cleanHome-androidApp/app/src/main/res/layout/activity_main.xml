<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido a CleanHome"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tu hogar limpio y reluciente a un solo clic de distancia."
        android:textSize="14sp"
        android:textColor="#4B5563"
        android:textAlignment="center"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/etCorreo"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="juan@ejemplo.com"
        android:inputType="textEmailAddress"
        android:background="#F3F4F6"
        android:textColor="#111827"
        android:textColorHint="#6B7280"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etContrasena"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Contraseña"
        android:inputType="textPassword"
        android:background="#F3F4F6"
        android:textColor="#111827"
        android:textColorHint="#6B7280"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <CheckBox
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Recordarme"
        android:textColor="#374151"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnIniciarSesion"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Iniciar Sesión"
        android:textColor="#FFFFFF"
        android:backgroundTint="#111827"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvRegistrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿No tienes una cuenta? Regístrate"
        android:textSize="14sp"
        android:textColor="#0D6EFD"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ingresa con una cuenta administradora"
        android:textSize="12sp"
        android:textColor="#6B7280" />
</LinearLayout>
